package com.ghost616.platform.systemtest;

import java.util.ArrayDeque;
import java.util.Deque;
import java.util.concurrent.ConcurrentHashMap;
import java.util.stream.Collectors;
import java.util.List;

import com.ghost616.platform.dto.model.ChatChunk;
import com.ghost616.platform.dto.model.ToolCallDelta;
import com.ghost616.platform.enums.HookPhase;
import com.ghost616.platform.service.agent.AgentExecutionContext;
import com.ghost616.platform.service.agent.SessionManager;
import com.ghost616.platform.service.agent.invoker.SystemPostHook;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Component;

@Slf4j
@Component
public class ToolCallBufferHook implements SystemPostHook {

    private static class ToolAccumulator {
        final StringBuilder id = new StringBuilder();
        final StringBuilder name = new StringBuilder();
        final StringBuilder arguments = new StringBuilder();
    }

    private static class SessionBuffer {
        final StringBuilder contentBuffer = new StringBuilder();
        final ConcurrentHashMap<Integer, ToolAccumulator> toolCallBuffers = new ConcurrentHashMap<>();
    }

    private final ConcurrentHashMap<Long, Deque<SessionManager.ToolCallData>> toolCallQueues = new ConcurrentHashMap<>();
    private final ConcurrentHashMap<Long, SessionBuffer> buffers = new ConcurrentHashMap<>();

    @Override
    public HookPhase getPhase() {
        return HookPhase.AFTER_MESSAGE_RECEIVE;
    }

    @Override
    public void execute(AgentExecutionContext ctx, ChatChunk chunk) {
        if (chunk == null) {
            return;
        }
        Long sessionId = ctx.getSessionId();

        if ("tool_calls".equals(chunk.getFinishReason())) {
            SessionBuffer sb = buffers.remove(sessionId);
            if (sb == null) {
                return;
            }
            if (!sb.toolCallBuffers.isEmpty()) {
                List<SessionManager.ToolCallData> toolCalls = sb.toolCallBuffers.values().stream()
                        .map(a -> new SessionManager.ToolCallData(
                                a.id.toString(),
                                a.name.toString(),
                                a.arguments.toString()))
                        .collect(Collectors.toList());
                Deque<SessionManager.ToolCallData> queue = toolCallQueues.computeIfAbsent(sessionId,
                        k -> new ArrayDeque<>());
                queue.addAll(toolCalls);
                log.info("sessionId={} 已入队 {} 个工具调用", sessionId, toolCalls.size());
            }
            return;
        }

        SessionBuffer sb = buffers.computeIfAbsent(sessionId, k -> new SessionBuffer());
        if (chunk.getDelta() != null) {
            sb.contentBuffer.append(chunk.getDelta());
        }
        ToolCallDelta tc = chunk.getToolCall();
        if (tc != null) {
            ToolAccumulator acc = sb.toolCallBuffers.computeIfAbsent(tc.getIndex(), k -> new ToolAccumulator());
            if (tc.getId() != null) {
                acc.id.append(tc.getId());
            }
            if (tc.getName() != null) {
                acc.name.append(tc.getName());
            }
            if (tc.getArguments() != null) {
                acc.arguments.append(tc.getArguments());
            }
        }
    }

    public void enqueue(Long sessionId, SessionManager.ToolCallData toolCallData) {
        Deque<SessionManager.ToolCallData> queue = toolCallQueues.computeIfAbsent(sessionId,
                k -> new ArrayDeque<>());
        queue.addLast(toolCallData);
    }

    public SessionManager.ToolCallData poll(Long sessionId) {
        Deque<SessionManager.ToolCallData> queue = toolCallQueues.get(sessionId);
        if (queue == null || queue.isEmpty()) {
            return null;
        }
        return queue.pollFirst();
    }

    public boolean hasPending(Long sessionId) {
        Deque<SessionManager.ToolCallData> queue = toolCallQueues.get(sessionId);
        return queue != null && !queue.isEmpty();
    }

    public String getContent(Long sessionId) {
        SessionBuffer sb = buffers.get(sessionId);
        return sb != null ? sb.contentBuffer.toString() : null;
    }
}
