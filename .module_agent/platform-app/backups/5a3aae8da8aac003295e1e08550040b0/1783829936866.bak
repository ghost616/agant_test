package com.ghost616.platform.service.agent;

import com.ghost616.agentbase.dto.model.Message;
import com.ghost616.agentbase.service.agent.ContextDataProvider;
import com.ghost616.agentbase.service.agent.invoker.SubSessionCallback;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Component;

import java.util.concurrent.CompletableFuture;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.ExecutionException;

@Component
@RequiredArgsConstructor
public class DefaultSubSessionCallback implements SubSessionCallback {

    private static final Long NULL_PARENT_SENTINEL = Long.MIN_VALUE;

    private final ContextDataProvider contextDataProvider;

    private final ConcurrentHashMap<Long, SubSessionData> subSessionDataMap = new ConcurrentHashMap<>();

    @Override
    public Message execute(Long sessionId, String userMessage) {
        ContextDataProvider.AgentContextData context = contextDataProvider.loadAgentContext(sessionId);
        Long parentSessionId = context != null ? context.parentSessionId() : null;
        Long mapKey = parentSessionId != null ? parentSessionId : NULL_PARENT_SENTINEL;

        CompletableFuture<Message> messageResult = new CompletableFuture<>();
        SubSessionData data = new SubSessionData(sessionId, userMessage, messageResult);
        subSessionDataMap.put(mapKey, data);

        try {
            return messageResult.get();
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            throw new RuntimeException("SubSession execution interrupted", e);
        } catch (ExecutionException e) {
            throw new RuntimeException("SubSession execution failed", e.getCause());
        } finally {
            subSessionDataMap.remove(mapKey);
        }
    }

    public SubSessionData getSubSessionData(Long parentSessionId) {
        Long mapKey = parentSessionId != null ? parentSessionId : NULL_PARENT_SENTINEL;
        return subSessionDataMap.get(mapKey);
    }

    public static class SubSessionData {
        private final Long childSessionId;
        private final String userMessage;
        private final CompletableFuture<Message> messageResult;

        public SubSessionData(Long childSessionId, String userMessage, CompletableFuture<Message> messageResult) {
            this.childSessionId = childSessionId;
            this.userMessage = userMessage;
            this.messageResult = messageResult;
        }

        public Long getChildSessionId() {
            return childSessionId;
        }

        public String getUserMessage() {
            return userMessage;
        }

        public CompletableFuture<Message> getMessageResult() {
            return messageResult;
        }
    }
}
