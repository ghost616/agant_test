import { describe, it, expect } from 'vitest';
import { readFileSync } from 'fs';
import { resolve } from 'path';

describe('AgentChat 子会话相关 (静态验证)', () => {
  it('应导入 getSubSessionData 和 completeSubSession', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain('getSubSessionData');
    expect(source).toContain('completeSubSession');
  });

  it('handleSubSessionFlow 应调用 getSubSessionData(sessionId)', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    const handleSubBlock = source.match(/const handleSubSessionFlow[\s\S]*?}, \[sessionId, pollToolStatus\]\);/);
    expect(handleSubBlock).not.toBeNull();
    if (handleSubBlock) {
      expect(handleSubBlock[0]).toContain('getSubSessionData(sessionId)');
    }
  });

  it('handleSubSessionFlow 应在获取子会话数据后设置 Modal 状态', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain("setSubSessionId(childId)");
    expect(source).toContain("setSubSessionModalVisible(true)");
  });

  it('handleSubSessionFlow 应在子会话完成后调用 completeSubSession', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain('await completeSubSession(sessionId)');
  });

  it('handleSubSessionFlow 的 getSubSessionData 返回 null 时应提示错误并返回', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain("message.error('获取子会话数据失败')");
    expect(source).toContain("if (!data) {");
  });

  it('pollToolStatus 应检测 status.needsSubSessionFlow 并调用 handleSubSessionFlow 启动子会话', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    const pollBlock = source.match(/const pollToolStatus[\s\S]*?}, \[\]\);/);
    expect(pollBlock).not.toBeNull();
    if (pollBlock) {
      expect(pollBlock[0]).toContain('status.needsSubSessionFlow');
      expect(pollBlock[0]).toContain('handleSubSessionFlowRef.current!(toolId)');
    }
  });

  it('handleAbort 应同步中止子会话 (subToolAbortRef + subAbortRef)', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    const handleAbortBlock = source.match(/const handleAbort[\s\S]*?}, \[sessionId\]\);/);
    expect(handleAbortBlock).not.toBeNull();
    if (handleAbortBlock) {
      expect(handleAbortBlock[0]).toContain('subToolAbortRef.current = true');
      expect(handleAbortBlock[0]).toContain('subAbortRef.current');
    }
  });

  it('renderSubSessionModal 应包含子会话对话标题', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain('title=\"子会话对话\"');
  });

  it('handleSubSessionFlow 应使用 pollSubToolStatus 轮询子会话工具状态', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain('pollSubToolStatus');
    expect(source).toContain('getToolStatus(sid, tid)');
  });

  it('handleSubSessionFlow 应轮询主会话工具状态完成子会话流程', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain('await pollToolStatus(sessionId, toolId)');
  });

  it('子会话 Modal 应显示流式内容和推理内容', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain('subCurrentResponse');
    expect(source).toContain('subCurrentReasoning');
    expect(source).toContain('subLoading');
    expect(source).toContain('subToolExecuting');
  });

  it('子会话 Modal 关闭时应中止子会话', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    const modalBlock = source.match(/onCancel=\{\(\) => \{[\s\S]*?setSubSessionModalVisible\(false\);\s+\}\}/);
    expect(modalBlock).not.toBeNull();
    if (modalBlock) {
      expect(modalBlock[0]).toContain('subToolAbortRef.current = true');
    }
  });
});

describe('AgentChat handleAbort (static verification)', () => {
  it('should import stopChat from session service', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain("import {");
    expect(source).toContain("stopChat");
    expect(source).toContain("} from '../../services/session'");
  });

  it('handleAbort should call stopChat with sessionId', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain("stopChat(sessionId)");
    expect(source).toContain(".catch(() => {})");
  });

  it('handleAbort should set toolAbortRef and call abortRef.abort after stopChat', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    expect(source).toContain("toolAbortRef.current = true");
    expect(source).toContain("abortRef.current.abort()");
  });

  it('stopChat should be fire-and-forget (no await)', () => {
    const source = readFileSync(resolve(__dirname, '../AgentChat.tsx'), 'utf-8');
    const handleAbortBlock = source.match(/const handleAbort[\s\S]*?}, \[sessionId\]\);/);
    expect(handleAbortBlock).not.toBeNull();
    if (handleAbortBlock) {
      expect(handleAbortBlock[0]).toContain("stopChat(sessionId).catch(() => {})");
      expect(handleAbortBlock[0]).not.toContain("await stopChat");
    }
  });
});
