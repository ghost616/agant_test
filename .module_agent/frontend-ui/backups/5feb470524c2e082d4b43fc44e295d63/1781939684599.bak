import type { CommonStatus } from './common';

export type ToolType = 'JAVA' | 'TYPESCRIPT' | 'PYTHON';

export interface ToolConfig {
  id: string;
  name: string;
  toolType: ToolType;
  description: string;
  parameterSchema: string;
  returnSchema: string;
  implPath: string;
  status: CommonStatus;
  createTime: string;
  updateTime: string;
}

export type ToolFormData = Omit<ToolConfig, 'id' | 'status' | 'createTime' | 'updateTime'>;
